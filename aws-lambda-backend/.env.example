# AWS credentials for automatic CLI setup
AWS_ACCESS_KEY_ID=your-aws-access-key-id  # Your AWS access key ID
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key  # Your AWS secret access key

# DynamoDB table for users
USERS_TABLE=Users  # Name of the DynamoDB table for users
CATEGORIES_TABLE=Categories  # Name of the DynamoDB table for categories
EXPENSES_TABLE=Expenses  # Name of the DynamoDB table for expenses

# JWT secret for signing tokens
JWT_SECRET=expense_tracker_2026  # Secret key for JWT token generation

# AWS region
AWS_REGION=us-east-1  # AWS region for resources
